
# disable screen for docker
DISPLAY=:0
QT_QPA_PLATFORM=offscreen

# for my app
# DATABASE_URL=postgresql://tracker_user:pg_secure_password_here@localhost:5432/person_tracker

# for docker
DATABASE_URL=postgresql://tracker_user:pg_secure_password_here@postgres:5432/person_tracker

# for alembic
DATABASE_URL_ASYNC=postgresql+asyncpg://tracker_user:pg_secure_password_here@localhost:5432/person_tracker



GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# PostgreSQL
POSTGRES_USER=tracker_user
POSTGRES_PASSWORD=pg_secure_password_here
POSTGRES_DB=person_tracker

# pgAdmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin_password

# Redis
REDIS_HOST=redis
# REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# System
STARTUP_DURATION=300
PERSON_ABSENCE_THRESHOLD=600
# ALERT_COOLDOWN=600

# Video
FRAME_SKIP=2
BUFFER_SECONDS=4
POST_ROLL_SECONDS=4

# Web
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_DEBUG=False

# Telegram 


# API
API_SECRET_KEY=your-secret-key-here