                    "kind": "DataQuery",
                    "spec": {
                      "database": "postgres",
                      "editorMode": "code",
                      "format": "table",
                      "rawQuery": true,
                      "rawSql": "WITH last_gas AS (\n  SELECT EXTRACT(EPOCH FROM (NOW() - timestamp)) / 60 AS gas_min\n  FROM meter_readings ORDER BY timestamp DESC LIMIT 1\n),\nlast_person AS (\n  SELECT EXTRACT(EPOCH FROM (NOW() - timestamp)) / 60 AS person_min\n  FROM activity_logs \n  WHERE source = 'PERSON_DETECTOR' AND event_type = 'PERSON_DETECTED'\n  ORDER BY timestamp DESC LIMIT 1\n)\nSELECT \n  CASE \n    WHEN COALESCE(gas_min, 999) <= 3 THEN\n      COALESCE(\n        CASE \n          WHEN person_min < 1 THEN 'Just now'\n          ELSE CONCAT(FLOOR(person_min), 'm')\n        END,\n        'No detection'\n      )\n    ELSE \n      'GAS OFF'\n  END AS display_text,\n  gas_min,\n  last_person\nFROM last_gas CROSS JOIN last_person;",
                      "sql": {
                        "columns": [
                          {
                            "parameters": [],
                            "type": "function"
                          }
                        ],
                        "groupBy": [
                          {
                            "property": {
